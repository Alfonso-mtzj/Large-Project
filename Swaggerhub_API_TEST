openapi: 3.0.0

info:
  title: SkillTree API
  description: >
    Backend API for the SkillTree app — a D&D-themed real-life skill builder.
    Handles user registration, email verification, login, and password reset.
  version: 1.0.0
  contact:
    name: SkillTree Team

servers:
  - url: https://lifexpskilltree.xyz/api
    description: Production server (Digital Ocean)

tags:
  - name: Auth
    description: User registration, login, and password management

paths:

  # ── REGISTER ──────────────────────────────────────────────────────
  /register:
    post:
      tags:
        - Auth
      summary: Register a new user
      description: >
        Creates a new user account and sends a verification email.
        Returns success immediately — the email is sent in the background.
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              required:
                - firstName
                - lastName
                - username
                - email
                - password
              properties:
                firstName:
                  type: string
                  example: Alfonso
                lastName:
                  type: string
                  example: Rivas
                username:
                  type: string
                  example: alfonso123
                email:
                  type: string
                  format: email
                  example: alfonso@example.com
                password:
                  type: string
                  format: password
                  example: Password1!
      responses:
        '200':
          description: User registered successfully
          content:
            application/json:
              schema:
                type: object
                properties:
                  message:
                    type: string
                    example: "Registered successfully! Please check your email."
        '400':
          description: Email or username already exists
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'
              example:
                error: "User already exists"
        '500':
          description: Server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'

  # ── VERIFY EMAIL ───────────────────────────────────────────────────
  /verify/{token}:
    get:
      tags:
        - Auth
      summary: Verify a user's email address
      description: >
        Called when the user clicks the verification link in their email.
        Marks the account as verified so the user can log in.
      parameters:
        - name: token
          in: path
          required: true
          description: The verification token sent in the registration email
          schema:
            type: string
            example: 4f165ffce464a4f3b829af67680763cf6c2ceccc
      responses:
        '200':
          description: Email verified successfully
          content:
            text/plain:
              schema:
                type: string
                example: "Email verified successfully! You can now log in."
        '400':
          description: Token is invalid or has already been used
          content:
            text/plain:
              schema:
                type: string
                example: "Invalid or expired token"
        '500':
          description: Server error
          content:
            text/plain:
              schema:
                type: string
                example: "Server error"

  # ── LOGIN ──────────────────────────────────────────────────────────
  /login:
    post:
      tags:
        - Auth
      summary: Log in with email and password
      description: >
        Authenticates a verified user. Returns the user's profile data.
        The account must be email-verified before login is allowed.
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              required:
                - email
                - password
              properties:
                email:
                  type: string
                  format: email
                  example: alfonso@example.com
                password:
                  type: string
                  format: password
                  example: Password1!
      responses:
        '200':
          description: Login successful — returns user profile
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserProfile'
        '400':
          description: Invalid email or password
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'
              example:
                error: "Invalid email or password"
        '401':
          description: Account email has not been verified yet
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'
              example:
                error: "Email not verified"
        '500':
          description: Server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'

  # ── FORGOT PASSWORD ────────────────────────────────────────────────
  /forgot-password:
    post:
      tags:
        - Auth
      summary: Request a password reset email
      description: >
        Sends a password reset link to the provided email address.
        Always returns the same generic message whether the email
        exists or not — this is a security best practice so attackers
        cannot discover which emails are registered.
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              required:
                - email
              properties:
                email:
                  type: string
                  format: email
                  example: alfonso@example.com
      responses:
        '200':
          description: Generic success message (whether email exists or not)
          content:
            application/json:
              schema:
                type: object
                properties:
                  message:
                    type: string
                    example: "If that email exists, a password reset token has been sent."
        '400':
          description: Email field was not provided
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'
              example:
                error: "Email is required"
        '500':
          description: Server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'

  # ── RESET PASSWORD ─────────────────────────────────────────────────
  /reset-password/{token}:
    post:
      tags:
        - Auth
      summary: Reset password using token from email
      description: >
        Resets the user's password using the token from the reset email link.
        The token expires after 1 hour. The new password is hashed before saving.
      parameters:
        - name: token
          in: path
          required: true
          description: The reset token from the password reset email
          schema:
            type: string
            example: 2a8abac53bfc9954b692e65bcd9d0ce0723b09fe
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              required:
                - password
              properties:
                password:
                  type: string
                  format: password
                  description: The new password to set
                  example: NewPassword1!
      responses:
        '200':
          description: Password reset successfully
          content:
            application/json:
              schema:
                type: object
                properties:
                  message:
                    type: string
                    example: "Password reset successfully. You can now log in."
        '400':
          description: Token is invalid or expired, or password was not provided
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'
              examples:
                expired:
                  value:
                    error: "Invalid or expired reset token"
                missing:
                  value:
                    error: "Password is required"
        '500':
          description: Server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'

# ── REUSABLE SCHEMAS ───────────────────────────────────────────────────
components:
  schemas:

    # User profile returned on login
    UserProfile:
      type: object
      properties:
        id:
          type: string
          example: "6630f1a2b4e3c900123abc45"
        email:
          type: string
          example: "alfonso@example.com"
        username:
          type: string
          example: "alfonso123"
        firstName:
          type: string
          example: "Alfonso"
        lastName:
          type: string
          example: "Rivas"

    # Standard error response
    Error:
      type: object
      properties:
        error:
          type: string
          example: "Something went wrong"
